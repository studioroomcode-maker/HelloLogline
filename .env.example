# ──────────────────────────────────────────────────
# HelloLoglines — 환경변수 설정 예시
# 이 파일을 .env 로 복사하여 사용하세요.
# ──────────────────────────────────────────────────

# [권장] 서버 사이드 API 키 (브라우저에 노출되지 않음)
# 이 키가 설정되어 있으면 사용자가 UI에서 키를 직접 입력하지 않아도 됩니다.
ANTHROPIC_API_KEY=sk-ant-api03-...

# [선택] 프록시 서버 포트 (기본값: 3001)
# PORT=3001

# Sentry (선택 - 없으면 에러 모니터링 비활성화)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ── DB / Redis (선택 — 없으면 크레딧/레이트리미팅 비활성화됨) ────────────────
# 아래 중 하나만 설정하면 됩니다.

# 방법 1: Supabase (권장 — 크레딧 결제 시스템 포함)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# 방법 2: Upstash Redis REST API
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# 방법 3: 일반 Redis (직접 연결)
# REDIS_URL=redis://username:password@host:port
